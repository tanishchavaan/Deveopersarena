<div className="bg-white rounded-2xl shadow-md hover:shadow-xl overflow-hidden w-full max-w-[260px] mx-auto">
  <Link to={`/product/${product.id}`}>
    <img
      src={product.image}
      alt={product.name}
      className="w-full h-48 object-cover hover:scale-105"
    />
  </Link>
  <div className="p-4">
    <h3 className="text-lg font-semibold mb-1">{product.name}</h3>
    <p className="text-blue-600 font-bold mb-3">${product.price}</p>
    <button
      className="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700"
      onClick={() => dispatch(addToCart(product))}
    >
      Add to Cart
    </button>
  </div>
</div>
